# Flask configuratie
SECRET_KEY=vervang_met_willekeurige_string_min_32_tekens
FLASK_DEBUG=0
FLASK_HOST=0.0.0.0
FLASK_PORT=8080

# Database
DATABASE_URL=sqlite:///schoolportaal.db

# Beveiliging
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_HTTPONLY=1
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=3600

# Rate limiting
RATE_LIMIT_PER_DAY=1000
RATE_LIMIT_PER_HOUR=100
RATE_LIMIT_LOGIN_PER_MINUTE=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=schoolportaal.log